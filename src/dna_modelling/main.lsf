#BSUB -e Main_LCB%J.err
#BSUB -n 6
#BSUB -q gpuv100
#BSUB -gpu "num=1:mode=exclusive_process"
#BSUB -R "rusage[mem=1100]"
#BSUB -R "span[hosts=1]"
#BSUB -W 20:00
