#!/bin/bash
cd "$LS_SUBCWD" || exit 1

module purge
module load cuda/12.8.0
module load python3/3.12.11

source .venv/bin/activate

export OMP_NUM_THREADS=4
export MKL_NUM_THREADS=4

export LS_DIM=2
python src/dna_modelling/main.py
