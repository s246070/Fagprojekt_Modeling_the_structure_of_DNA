#!/bin/bash
cd "$LS_SUBCWD" || exit 1

module purge
module load cuda/12.6
module load python3/3.12.12

source .venv/bin/activate

export OMP_NUM_THREADS=4
export MKL_NUM_THREADS=4

python3 main.py