#!/bin/bash
cd "$LS_SUBCWD" || exit 1

module purge
module load cuda/12.6
module load python3/3.12.11
module load cudnn/v9.6.0.74-prod-cuda-12.X

source .venv/bin/activate

export OMP_NUM_THREADS=4
export MKL_NUM_THREADS=4

python src/dna_modelling/main.py